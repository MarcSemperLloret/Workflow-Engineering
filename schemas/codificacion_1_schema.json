{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "paper_id",
    "year",
    "venue_type",
    "domain_class",
    "task_class",
    "target_class",
    "dataset_family",
    "has_public_code",
    "has_public_dataset",
    "horizon_type",
    "horizon_min_value",
    "horizon_max_value",
    "horizon_unit",
    "frequency_value",
    "frequency_unit",
    "graph_node_count_min",
    "graph_node_count_max",
    "node_unit",
    "graph_node_count_status",
    "coding_status",
    "confidence"
  ],
  "properties": {
    "paper_id": { "type": "string" },
    "year": { "type": "string", "pattern": "^(\\d{4}|not_reported|ambiguous)$" },
    "venue_type": { "enum": ["conference", "journal", "preprint", "competition_workshop", "not_reported"] },
    "domain_class": { "enum": ["traffic", "air_quality", "energy_pv", "epidemiology", "network_traffic", "general_network_timeseries", "multivariate_timeseries"] },
    "task_class": { "enum": ["traffic_forecasting", "travel_time_forecasting", "air_quality_forecasting", "pv_power_forecasting", "covid_forecasting", "network_traffic_forecasting", "network_timeseries_prediction", "multivariate_timeseries_forecasting", "benchmark_evaluation"] },
    "target_class": { "enum": ["traffic_speed", "traffic_flow", "traffic_speed_and_flow", "travel_time", "aqi", "pv_power", "covid_cases", "network_bandwidth", "multiple_targets"] },
    "dataset_family": { "type": "string" },
    "has_public_code": { "enum": ["yes", "no", "not_reported"] },
    "has_public_dataset": { "enum": ["yes", "no", "not_reported"] },
    "horizon_type": { "enum": ["single_horizon", "multi_horizon", "sequence", "dataset_specific", "not_reported"] },
    "horizon_min_value": { "type": "string" },
    "horizon_max_value": { "type": "string" },
    "horizon_unit": { "enum": ["minutes", "hours", "steps", "days", "weeks", "mixed", "dataset_specific", "not_reported", "not_applicable"] },
    "frequency_value": { "type": "string" },
    "frequency_unit": { "enum": ["seconds", "minutes", "hours", "days", "mixed", "dataset_specific", "not_reported", "not_applicable"] },
    "graph_node_count_min": { "type": "string" },
    "graph_node_count_max": { "type": "string" },
    "node_unit": { "enum": ["sensors", "stations", "road_segments", "counties", "links", "nodes", "mixed", "not_reported"] },
    "graph_node_count_status": { "enum": ["found", "partial", "not_reported", "ambiguous"] },
    "coding_status": { "enum": ["complete", "partial"] },
    "confidence": { "enum": ["high", "medium", "low"] }
  }
}
